<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Заявка на перевод в отдел | EMS</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family:
                Arial,
                Helvetica,
                sans-serif;

            background:
                radial-gradient(
                    circle at top right,
                    rgba(245, 158, 11, 0.16),
                    transparent 32%
                ),
                radial-gradient(
                    circle at bottom left,
                    rgba(239, 68, 68, 0.10),
                    transparent 30%
                ),
                #0f172a;

            color: #f8fafc;
        }

        a {
            color: inherit;
        }

        .page-container {
            width: 100%;
            max-width: 820px;
            margin: 0 auto;
            padding: 36px 20px 60px;
        }

        .top-panel {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 22px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #fcd34d;
            font-size: 15px;
            font-weight: 700;
            text-decoration: none;
            transition: 0.2s ease;
        }

        .back-link:hover {
            color: #fde68a;
            transform: translateX(-2px);
        }

        .user-panel {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #cbd5e1;
            font-size: 14px;
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border: 1px solid rgba(245, 158, 11, 0.35);
            border-radius: 50%;
            object-fit: cover;
            background: #1e293b;
        }

        .form-card {
            overflow: hidden;
            border: 1px solid rgba(245, 158, 11, 0.25);
            border-radius: 22px;

            background:
                linear-gradient(
                    145deg,
                    rgba(30, 41, 59, 0.98),
                    rgba(15, 23, 42, 0.98)
                );

            box-shadow:
                0 30px 70px rgba(0, 0, 0, 0.35),
                0 0 45px rgba(245, 158, 11, 0.04);
        }

        .form-header {
            padding: 30px 32px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.14);

            background:
                linear-gradient(
                    135deg,
                    rgba(245, 158, 11, 0.13),
                    rgba(30, 41, 59, 0.15)
                );
        }

        .form-header-content {
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .form-icon {
            display: flex;
            flex: 0 0 auto;
            align-items: center;
            justify-content: center;

            width: 54px;
            height: 54px;

            border: 1px solid rgba(245, 158, 11, 0.35);
            border-radius: 15px;

            background: rgba(245, 158, 11, 0.12);
            font-size: 27px;
        }

        .form-title {
            margin: 0 0 9px;
            font-size: 29px;
            line-height: 1.2;
        }

        .form-description {
            max-width: 620px;
            margin: 0;
            color: #94a3b8;
            font-size: 15px;
            line-height: 1.6;
        }

        .form-content {
            padding: 30px 32px 34px;
        }

        .alert {
            margin-bottom: 24px;
            padding: 15px 17px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.5;
        }

        .alert-error {
            border: 1px solid rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.30);
            color: #fecaca;
        }

        .alert-success {
            border: 1px solid rgba(74, 222, 128, 0.30);
            background: rgba(20, 83, 45, 0.30);
            color: #bbf7d0;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 6px 0 20px;
            color: #f8fafc;
            font-size: 17px;
            font-weight: 700;
        }

        .section-title::after {
            flex: 1;
            height: 1px;
            background: rgba(148, 163, 184, 0.14);
            content: "";
        }

        .form-group {
            margin-bottom: 21px;
        }

        .form-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #e2e8f0;
            font-size: 14px;
            font-weight: 700;
        }

        .required {
            color: #f87171;
        }

        input,
        select {
            width: 100%;
            min-height: 49px;
            padding: 12px 14px;

            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 11px;
            outline: none;

            background: rgba(15, 23, 42, 0.92);
            color: #f8fafc;

            font-family: inherit;
            font-size: 15px;

            transition:
                border-color 0.2s ease,
                box-shadow 0.2s ease,
                background 0.2s ease;
        }

        input::placeholder {
            color: #64748b;
        }

        input:focus,
        select:focus {
            border-color: rgba(245, 158, 11, 0.78);
            background: rgba(15, 23, 42, 1);
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.11);
        }

        input[readonly],
        select:disabled {
            cursor: not-allowed;
            border-color: rgba(148, 163, 184, 0.14);
            background: rgba(30, 41, 59, 0.72);
            color: #94a3b8;
        }

        select option {
            background: #0f172a;
            color: #f8fafc;
        }

        .field-hint {
            margin: 8px 0 0;
            color: #94a3b8;
            font-size: 13px;
            line-height: 1.45;
        }

        .field-hint.active {
            color: #fcd34d;
        }

        .information-box {
            margin: 4px 0 24px;
            padding: 15px 17px;

            border: 1px solid rgba(59, 130, 246, 0.23);
            border-radius: 12px;

            background: rgba(30, 64, 175, 0.11);
            color: #bfdbfe;

            font-size: 13px;
            line-height: 1.55;
        }

        .submit-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;

            width: 100%;
            min-height: 52px;
            margin-top: 8px;
            padding: 12px 20px;

            border: 0;
            border-radius: 12px;

            background:
                linear-gradient(
                    135deg,
                    #f59e0b,
                    #d97706
                );

            color: #ffffff;
            font-family: inherit;
            font-size: 16px;
            font-weight: 800;

            cursor: pointer;

            box-shadow: 0 10px 28px rgba(217, 119, 6, 0.19);

            transition:
                transform 0.2s ease,
                box-shadow 0.2s ease,
                opacity 0.2s ease;
        }

        .submit-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 34px rgba(217, 119, 6, 0.27);
        }

        .submit-button:active {
            transform: translateY(0);
        }

        .submit-button:disabled {
            cursor: wait;
            opacity: 0.7;
            transform: none;
            box-shadow: none;
        }

        @media (max-width: 680px) {
            .page-container {
                padding: 22px 13px 40px;
            }

            .top-panel {
                align-items: flex-start;
                flex-direction: column;
            }

            .form-header,
            .form-content {
                padding: 24px 20px;
            }

            .form-header-content {
                gap: 13px;
            }

            .form-icon {
                width: 47px;
                height: 47px;
                font-size: 23px;
            }

            .form-title {
                font-size: 24px;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }
        }
    </style>
</head>

<body>
    <main class="page-container">
        <div class="top-panel">
            <a
                class="back-link"
                href="/dashboard"
            >
                ← Вернуться в личный кабинет
            </a>

            <div class="user-panel">
                <% if (user.avatar) { %>
                    <img
                        class="user-avatar"
                        src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png"
                        alt="Аватар пользователя"
                    >
                <% } %>

                <span>
                    <%= user.global_name || user.username %>
                </span>
            </div>
        </div>

        <section class="form-card">
            <header class="form-header">
                <div class="form-header-content">
                    <div class="form-icon">
                        🔄
                    </div>

                    <div>
                        <h1 class="form-title">
                            Заявка на перевод в отдел
                        </h1>

                        <p class="form-description">
                            Заполните заявление на перевод в другой отдел EMS.
                            После отправки заявка автоматически поступит
                            руководству выбранного отдела.
                        </p>
                    </div>
                </div>
            </header>

            <div class="form-content">
                <% if (error) { %>
                    <div class="alert alert-error">
                        <strong>Ошибка:</strong>
                        <%= error %>
                    </div>
                <% } %>

                <% if (success) { %>
                    <div class="alert alert-success">
                        <strong>Готово:</strong>
                        <%= success %>
                    </div>
                <% } %>

                <form
                    id="department-transfer-form"
                    method="POST"
                    action="/forms/department-transfer"
                >
                    <div class="section-title">Данные заявителя</div>

                    <div class="form-group">
                        <label for="discordId">Discord ID</label>
                        <input id="discordId" type="text" value="<%= user.id %>" readonly>
                        <p class="field-hint">Discord ID получен автоматически из вашей сессии.</p>
                    </div>

                    <div class="form-group">
                        <label for="employeeName">Фамилия Имя | Статик <span class="required">*</span></label>
                        <input id="employeeName" name="employeeName" type="text" maxlength="120"
                            placeholder="Например: Lombardo Taylor | 233701"
                            value="<%= formData.employeeName || "" %>" autocomplete="off" required>
                    </div>

                    <div class="section-title">Направление перевода</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="fromDepartment">Из какого отдела переводитесь <span class="required">*</span></label>
                            <select id="fromDepartment" name="fromDepartment" required>
                                <option value="">Выберите отдел</option>
                                <% ["HAD", "PM", "SD", "EMT", "DI", "PSED"].forEach((department) => { %>
                                    <option value="<%= department %>" <%= formData.fromDepartment === department ? "selected" : "" %>><%= department %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="toDepartment">В какой отдел переводитесь <span class="required">*</span></label>
                            <select id="toDepartment" name="toDepartment" required>
                                <option value="">Выберите отдел</option>
                                <% ["HAD", "SD", "EMT", "DI", "PSED"].forEach((department) => { %>
                                    <option value="<%= department %>" <%= formData.toDepartment === department ? "selected" : "" %>><%= department %></option>
                                <% }) %>
                            </select>
                            <p class="field-hint">Отдел PM недоступен для подачи заявки на перевод.</p>
                        </div>
                    </div>

                    <div id="same-department-warning" class="alert alert-error" style="display:none;">
                        Нельзя подать заявку на перевод в тот же отдел.
                    </div>

                    <div class="section-title">Сведения о сотруднике</div>

                    <div class="form-group">
                        <label for="onlineAndPrime">Среднесуточный онлайн и прайм-тайм <span class="required">*</span></label>
                        <input id="onlineAndPrime" name="onlineAndPrime" type="text" maxlength="600"
                            placeholder="Например: 4–6 часов, 18:00–23:00 МСК"
                            value="<%= formData.onlineAndPrime || "" %>" required>
                    </div>

                    <div id="emt-section" class="information-box" style="display:none;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label for="flightSkill">Процент навыка полёта <span class="required">*</span></label>
                            <input id="flightSkill" name="flightSkill" type="number" min="0" max="100" step="1"
                                placeholder="Введите значение от 0 до 100"
                                value="<%= formData.flightSkill || "" %>">
                            <p class="field-hint">Поле обязательно только при переводе в отдел EMT.</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="developmentIdeas">Идеи по развитию отдела и чем собираетесь заниматься</label>
                        <textarea id="developmentIdeas" name="developmentIdeas" maxlength="1500"
                            placeholder="Опишите ваши идеи, планы и предполагаемые обязанности в отделе..."
                            style="width:100%; min-height:120px; padding:12px 14px; border:1px solid rgba(148,163,184,.24); border-radius:11px; outline:none; background:rgba(15,23,42,.92); color:#f8fafc; font:inherit; resize:vertical;"><%= formData.developmentIdeas || "" %></textarea>
                        <p class="field-hint">Поле заполняется по желанию.</p>
                    </div>

                    <div class="information-box">
                        Заявка будет отправлена в канал выбранного отдела, а руководство отдела получит упоминание.
                    </div>

                    <button id="submit-button" class="submit-button" type="submit">
                        <span>🔄</span>
                        <span id="submit-button-text">Отправить заявку</span>
                    </button>
                </form>
            </div>
        </section>
    </main>

    <script>
        const transferForm = document.getElementById("department-transfer-form");
        const fromDepartment = document.getElementById("fromDepartment");
        const toDepartment = document.getElementById("toDepartment");
        const emtSection = document.getElementById("emt-section");
        const flightSkill = document.getElementById("flightSkill");
        const warning = document.getElementById("same-department-warning");
        const submitButton = document.getElementById("submit-button");
        const submitButtonText = document.getElementById("submit-button-text");

        function updateFormState() {
            const sameDepartment = fromDepartment.value && toDepartment.value && fromDepartment.value === toDepartment.value;
            warning.style.display = sameDepartment ? "block" : "none";
            submitButton.disabled = Boolean(sameDepartment);

            const isEmt = toDepartment.value === "EMT";
            emtSection.style.display = isEmt ? "block" : "none";
            flightSkill.required = isEmt;
            if (!isEmt) flightSkill.value = "";
        }

        fromDepartment.addEventListener("change", updateFormState);
        toDepartment.addEventListener("change", updateFormState);

        transferForm.addEventListener("submit", function (event) {
            if (fromDepartment.value === toDepartment.value) {
                event.preventDefault();
                updateFormState();
                return;
            }

            submitButton.disabled = true;
            submitButtonText.textContent = "Отправка заявки...";
        });

        updateFormState();
    </script>
</body>
</html>