<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Личный кабинет</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: #111827;
            color: #ffffff;
        }

        .container {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .profile {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 30px;
            border-radius: 18px;
            background: #1f2937;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
        }

        .avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            background: #374151;
        }

        .profile-info h1 {
            margin: 0 0 10px;
        }

        .profile-info p {
            margin: 6px 0;
            color: #cbd5e1;
        }

        .actions {
            margin-top: 25px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .button {
            display: inline-block;
            padding: 13px 20px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        .primary {
            background: #22c55e;
            color: #ffffff;
        }

        .primary:hover {
            background: #16a34a;
        }

        .logout {
            background: #ef4444;
            color: #ffffff;
        }

        .logout:hover {
            background: #dc2626;
        }
        .resignation-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 260px;
    padding: 14px 22px;
    border-radius: 12px;
    background: #dc2626;
    color: #ffffff;
    font-size: 16px;
    font-weight: bold;
    text-decoration: none;
    transition: 0.2s ease;
    box-shadow: 0 10px 25px rgba(220, 38, 38, 0.25);
}

.resignation-button:hover {
    background: #b91c1c;
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(220, 38, 38, 0.35);
}
    </style>
</head>

<body>
    <div class="container">
        <div class="profile">

            <% if (user.avatar) { %>
                <img
                    class="avatar"
                    src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=256"
                    alt="Discord avatar"
                >
            <% } else { %>
                <img
                    class="avatar"
                    src="https://cdn.discordapp.com/embed/avatars/0.png"
                    alt="Discord avatar"
                >
            <% } %>

            <div class="profile-info">
                <h1>
                    Добро пожаловать,
                    <%= user.global_name || user.username %>
                </h1>

                <p>
                    <strong>Username:</strong>
                    <%= user.username %>
                </p>

                <p>
                    <strong>Discord ID:</strong>
                    <%= user.id %>
                </p>
            </div>
        </div>

        <div class="actions">
           <a href="/resignation" class="resignation-button">
    Подать заявление на увольнение
</a>

            <a class="button logout" href="/logout">
                Выйти
            </a>
        </div>
    </div>
</body>
</html>
